generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  HSEQ_MANAGER
  OPERATIONS
  CLIENT
  VIEWER
}

enum WorkOrderStatus {
  nueva
  planificada
  en_proceso
  detenida
  revision
  completada
  cerrada
}

enum Priority {
  baja
  media
  alta
  critica
}

enum HseqType {
  inspeccion
  incidente
  accion_correctiva
  capacitacion
  permiso_trabajo
  matriz_riesgo
}

enum Norm {
  ISO_45001
  ISO_9001
  ISO_14001
  DS_44
}

enum HseqStatus {
  abierto
  en_revision
  cerrado
  vencido
}

enum WorkerProfile {
  empleado
  supervisor
}

enum WorkerEngagement {
  permanente
  spot
}

enum RiskLevel {
  bajo
  medio
  alto
  critico
}

enum AstStatus {
  borrador
  en_revision
  aprobado
  requiere_revalidacion
  cerrado
}

enum PermitType {
  caliente
  izaje_critico
  altura
  loto
  electrico
  maquinaria
  espacio_confinado
}

enum PermitStatus {
  borrador
  aprobado
  activo
  suspendido
  cerrado
  vencido
}

model Company {
  id        String   @id @default(uuid())
  name      String
  rut       String   @unique
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients      Client[]
  projects     Project[]
  users        User[]
  workers      Worker[]
  equipment    Equipment[]
  materials    Material[]
  competencies Competency[]
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  rut       String?  @unique
  name      String
  password  String
  role      UserRole
  active    Boolean  @default(true)
  companyId String?
  clientId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([companyId])
  @@index([clientId])
  @@index([role])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Client {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  rut         String?
  industry    String?
  address     String?
  phone       String?
  email       String?
  paymentTerm Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts   Contact[]
  workOrders WorkOrder[]
  projects   Project[]
  users      User[]

  @@index([companyId])
}

model Contact {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  role      String?
  email     String?
  phone     String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Project {
  id          String    @id @default(uuid())
  companyId   String
  clientId    String?
  name        String
  code        String?
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("activo")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client     Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  workOrders WorkOrder[]
  ganttTasks GanttTask[]

  @@index([companyId])
  @@index([clientId])
  @@index([status])
}

model WorkOrder {
  id            String          @id @default(uuid())
  code          String          @unique
  title         String
  description   String?
  status        WorkOrderStatus @default(nueva)
  priority      Priority        @default(media)
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  /// @check (progress >= 0 AND progress <= 100)
  progress      Float           @default(0)
  responsibleId String?
  clientId      String?
  projectId     String?
  estimatedCost Decimal?        @db.Decimal(19, 4)
  actualCost    Decimal?        @db.Decimal(19, 4)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  client      Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  responsible Worker?            @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
  tasks       WorkOrderTask[]
  assignments WorkerAssignment[]
  documents   Document[]
  auditLogs   AuditLog[]
  ganttTasks  GanttTask[]
  asts        Ast[]
  permits     WorkPermit[]

  // ── Performance indexes for dashboard queries ──
  @@index([status])
  @@index([clientId])
  @@index([projectId])
  @@index([responsibleId])
  @@index([dueDate])
  @@index([createdAt])
  @@index([status, dueDate])
}

model WorkOrderTask {
  id             String    @id @default(uuid())
  workOrderId    String
  title          String
  description    String?
  processArea    String?
  critical       Boolean   @default(false)
  requiresPermit Boolean   @default(false)
  progress       Float     @default(0)
  completed      Boolean   @default(false)
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workOrder WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  asts      Ast[]
  permits   WorkPermit[]

  @@index([workOrderId])
  @@index([completed])
  @@index([critical])
  @@index([requiresPermit])
}

model Worker {
  id                  String           @id @default(uuid())
  companyId           String
  name                String
  rut                 String           @unique
  position            String
  specialty           String?
  status              String           @default("activo")
  profile             WorkerProfile    @default(empleado)
  engagement          WorkerEngagement @default(permanente)
  canCreateWorkers    Boolean          @default(false)
  canAssignWorkOrders Boolean          @default(false)
  spotDescription     String?
  certifications      String?
  criticalExpires     DateTime?
  phone               String?
  email               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ledOrders    WorkOrder[]
  assignments  WorkerAssignment[]
  hseqRecords  HseqRecord[]
  competencies Competency[]

  @@index([companyId])
  @@index([status])
  @@index([profile])
  @@index([engagement])
}

model WorkerAssignment {
  id          String    @id @default(uuid())
  workerId    String
  workOrderId String
  startDate   DateTime?
  endDate     DateTime?
  hours       Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@unique([workerId, workOrderId])
  @@index([workerId])
  @@index([workOrderId])
}

model GanttTask {
  id           String   @id @default(uuid())
  projectId    String
  workOrderId  String?
  name         String
  startDate    DateTime
  endDate      DateTime
  progress     Float    @default(0)
  status       String   @default("pendiente")
  dependencies String?
  responsible  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([workOrderId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model Equipment {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  code        String?   @unique
  type        String?
  status      String    @default("disponible")
  lastService DateTime?
  nextService DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  asts           Ast[]
  permits        WorkPermit[]
  certifications EquipmentCertification[]

  @@index([companyId])
  @@index([status])
}

model Ast {
  id              String    @id @default(uuid())
  workOrderId     String
  workOrderTaskId String?
  area            String
  equipmentId     String?
  riskLevel       RiskLevel
  status          AstStatus @default(borrador)
  version         Int       @default(1)
  supervisor      String?
  preStartChecks  String?
  evidence        String?
  changeReason    String?
  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workOrder     WorkOrder      @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workOrderTask WorkOrderTask? @relation(fields: [workOrderTaskId], references: [id], onDelete: SetNull)
  equipment     Equipment?     @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  steps         AstStep[]
  permits       WorkPermit[]

  @@index([workOrderId])
  @@index([workOrderTaskId])
  @@index([equipmentId])
  @@index([riskLevel])
  @@index([status])
}

model AstStep {
  id          String   @id @default(uuid())
  astId       String
  stepOrder   Int
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ast     Ast         @relation(fields: [astId], references: [id], onDelete: Cascade)
  hazards AstHazard[]

  @@index([astId])
}

model AstHazard {
  id           String    @id @default(uuid())
  astStepId    String
  hazardType   String
  initialRisk  RiskLevel
  controls     String
  residualRisk RiskLevel
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  astStep AstStep @relation(fields: [astStepId], references: [id], onDelete: Cascade)

  @@index([astStepId])
  @@index([initialRisk])
  @@index([residualRisk])
}

model WorkPermit {
  id              String       @id @default(uuid())
  type            PermitType
  workOrderId     String
  workOrderTaskId String?
  astId           String
  area            String
  equipmentId     String?
  startAt         DateTime
  endAt           DateTime
  status          PermitStatus @default(borrador)
  preconditions   String?
  approvedBy      String?
  approvedAt      DateTime?
  suspendedReason String?
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workOrder     WorkOrder             @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workOrderTask WorkOrderTask?        @relation(fields: [workOrderTaskId], references: [id], onDelete: SetNull)
  ast           Ast                   @relation(fields: [astId], references: [id], onDelete: Restrict)
  equipment     Equipment?            @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  checklist     PermitChecklistItem[]

  @@index([workOrderId])
  @@index([workOrderTaskId])
  @@index([astId])
  @@index([equipmentId])
  @@index([type])
  @@index([status])
  @@index([endAt])
}

model PermitChecklistItem {
  id        String    @id @default(uuid())
  permitId  String
  label     String
  required  Boolean   @default(true)
  checked   Boolean   @default(false)
  checkedBy String?
  checkedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  permit WorkPermit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([checked])
}

model EquipmentCertification {
  id          String    @id @default(uuid())
  equipmentId String
  certType    String
  validFrom   DateTime?
  validTo     DateTime
  status      String    @default("vigente")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([validTo])
  @@index([status])
}

model Competency {
  id             String   @id @default(uuid())
  companyId      String
  workerId       String
  competencyType String
  issuer         String?
  validTo        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker  Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([workerId])
  @@index([competencyType])
  @@index([validTo])
}

model Material {
  id        String   @id @default(uuid())
  companyId String
  name      String
  code      String?  @unique
  unit      String?
  stock     Float    @default(0)
  minStock  Float?
  cost      Decimal? @db.Decimal(19, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Document {
  id           String   @id @default(uuid())
  workOrderId  String?
  hseqRecordId String?
  name         String
  url          String
  type         String?
  public       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workOrder  WorkOrder?  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  hseqRecord HseqRecord? @relation(fields: [hseqRecordId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([hseqRecordId])
}

model HseqRecord {
  id                 String     @id @default(uuid())
  companyId          String
  type               HseqType
  norm               Norm
  description        String
  responsibleId      String?
  date               DateTime   @default(now())
  dueDate            DateTime?
  status             HseqStatus @default(abierto)
  evidenceDocumental String?
  signatureRequired  Boolean    @default(false)
  signed             Boolean    @default(false)
  signedAt           DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  responsible Worker?      @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
  actions     HseqAction[]
  documents   Document[]

  // ── Critical indexes for HSEQ dashboard alerts ──
  @@index([companyId])
  @@index([responsibleId])
  @@index([status])
  @@index([dueDate])
  @@index([norm])
  @@index([type])
  @@index([status, dueDate])
}

model HseqAction {
  id           String    @id @default(uuid())
  hseqRecordId String
  description  String
  responsible  String?
  dueDate      DateTime?
  completed    Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  hseqRecord HseqRecord @relation(fields: [hseqRecordId], references: [id], onDelete: Cascade)

  @@index([hseqRecordId])
  @@index([dueDate])
  @@index([completed])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  workOrderId String?
  action      String
  entity      String
  entityId    String?
  metadata    String?
  createdAt   DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workOrderId])
  @@index([entityId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}
